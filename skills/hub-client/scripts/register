#!/bin/bash
# 注册服务 - 将本地服务注册到 Hub

HUB_WS_URL="${HUB_WS_URL:-ws://localhost:8765}"

# 检查参数
if [ $# -lt 1 ]; then
    echo "用法: register <skill_dir> [--name <name>] [--description <desc>]"
    echo ""
    echo "参数:"
    echo "  skill_dir      包含 SKILL.md 的目录路径"
    echo ""
    echo "选项:"
    echo "  --name         服务名称 (默认从 SKILL.md 读取)"
    echo "  --description  服务描述 (默认从 SKILL.md 读取)"
    echo ""
    echo "环境变量:"
    echo "  HUB_WS_URL    Hub WebSocket 地址 (默认: ws://localhost:8765)"
    echo ""
    echo "示例:"
    echo "  register ./my-service-skill --name my-service"
    exit 1
fi

SKILL_DIR="$1"
shift

# 解析可选参数
NAME=""
DESCRIPTION=""
while [[ $# -gt 0 ]]; do
    case $1 in
        --name|-n)
            NAME="$2"
            shift 2
            ;;
        --description|-d)
            DESCRIPTION="$2"
            shift 2
            ;;
        *)
            echo "未知参数: $1"
            exit 1
            ;;
    esac
done

# 检查 skill 目录
if [ ! -d "$SKILL_DIR" ]; then
    echo "错误: 目录不存在: $SKILL_DIR"
    exit 1
fi

# 检查 SKILL.md
SKILL_MD="${SKILL_DIR}/SKILL.md"
if [ ! -f "$SKILL_MD" ]; then
    echo "错误: SKILL.md 不存在: $SKILL_MD"
    exit 1
fi

# 使用 Python 客户端注册
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

python3 -c "
import asyncio
import sys
sys.path.insert(0, '${PROJECT_ROOT}')

from client.client import LocalServiceRunner

async def dummy_handler(**params):
    return {'status': 'ok', 'message': 'Service is running'}

async def main():
    runner = LocalServiceRunner(
        name='${NAME}' if '${NAME}' else 'service',
        description='${DESCRIPTION}' if '${DESCRIPTION}' else 'Service from ${SKILL_DIR}',
        skill_dir='${SKILL_DIR}',
        hub_url='${HUB_WS_URL}'
    )
    
    print('Registering service...')
    print('Press Ctrl+C to stop')
    
    await runner.run()

asyncio.run(main())
"
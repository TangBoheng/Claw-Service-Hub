# Claw Service Hub Configuration
# Copy this file to .env and customize values

# Server Configuration
HUB_HOST=0.0.0.0
HUB_PORT=8765

# Security
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=

# TLS/SSL (optional)
# TLS_ENABLED=false
# TLS_CERT=
# TLS_KEY=

# Logging
LOG_LEVEL=INFO

# Database (optional)
# DATABASE_URL=sqlite:///./claw_hub.db
